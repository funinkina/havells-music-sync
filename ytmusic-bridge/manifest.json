{
  "manifest_version": 3,
  "name": "YT Music Bridge",
  "version": "1.1",
  "permissions": [],
  "host_permissions": [
    "https://music.youtube.com/*",
    "http://127.0.0.1:9001/*",
    "http://localhost:9001/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://music.youtube.com/*"],
      "js": ["page.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": ["https://music.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
