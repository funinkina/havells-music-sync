{
  "manifest_version": 3,
  "name": "YT Music Bridge",
  "version": "1.0",
  "permissions": [],
  "host_permissions": [
    "https://music.youtube.com/*",
    "http://127.0.0.1:9001/*",
    "http://localhost:9001/*"
  ],
    "background": {
      "service_worker": "background.js"
    },
    "content_scripts": [
      {
        "matches": ["https://music.youtube.com/*"],
        "js": ["content.js"],
        "run_at": "document_idle"
      }
    ]
  }
